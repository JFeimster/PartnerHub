<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="1600" viewBox="0 0 1200 1600">
  <rect width="1200" height="1600" fill="#ffffff"/>
  <rect x="60" y="60" width="1080" height="1480" fill="#f4f6fb" stroke="#0b1220" stroke-width="18"/>
  <text x="120" y="190" font-family="ui-sans-serif, system-ui" font-size="64" font-weight="900" fill="#0b1220">First Deal Checklist</text>
  <text x="120" y="265" font-family="ui-sans-serif, system-ui" font-size="28" font-weight="700" fill="#0b1220">Quick-start guide (demo placeholder)</text>

  <rect x="120" y="330" width="960" height="90" fill="#10b981" stroke="#0b1220" stroke-width="12"/>
  <text x="150" y="390" font-family="ui-sans-serif, system-ui" font-size="28" font-weight="900" fill="#0b1220">1) Qualify the prospect</text>

  <rect x="120" y="460" width="960" height="90" fill="#ffffff" stroke="#0b1220" stroke-width="12"/>
  <text x="150" y="520" font-family="ui-sans-serif, system-ui" font-size="28" font-weight="800" fill="#0b1220">2) Collect required docs</text>

  <rect x="120" y="590" width="960" height="90" fill="#ffffff" stroke="#0b1220" stroke-width="12"/>
  <text x="150" y="650" font-family="ui-sans-serif, system-ui" font-size="28" font-weight="800" fill="#0b1220">3) Submit clean application</text>

  <rect x="120" y="720" width="960" height="90" fill="#ffffff" stroke="#0b1220" stroke-width="12"/>
  <text x="150" y="780" font-family="ui-sans-serif, system-ui" font-size="28" font-weight="800" fill="#0b1220">4) Follow up daily</text>

  <rect x="120" y="850" width="960" height="90" fill="#f59e0b" stroke="#0b1220" stroke-width="12"/>
  <text x="150" y="910" font-family="ui-sans-serif, system-ui" font-size="28" font-weight="900" fill="#0b1220">5) Close & get paid</text>

  <text x="120" y="1040" font-family="ui-sans-serif, system-ui" font-size="22" font-weight="700" fill="#0b1220">Notes:</text>
  <rect x="120" y="1070" width="960" height="360" fill="#ffffff" stroke="#0b1220" stroke-width="12"/>
</svg>
